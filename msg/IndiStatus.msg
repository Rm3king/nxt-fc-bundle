uint64 timestamp              # time since system start (microseconds)
uint64 timestamp_sample       # timestamp of the gyro sample (microseconds)

uint8 MODE_PID = 0
uint8 MODE_INDI = 1
uint8 MODE_SHADOW = 2         # PID drives the vehicle; INDI computed and logged only
uint8 mode                    # active controller mode

uint8 SOURCE_NONE = 0
uint8 SOURCE_ACCEL_HEADING = 1
uint8 SOURCE_CTBR = 2
uint8 setpoint_source         # active INDI setpoint adapter

uint8 FLAG_FALLBACK = 1       # INDI requested but rejected/fell back to PID
uint8 FLAG_COMP_TIMEOUT = 2   # compensation stream stale
uint8 FLAG_SP_TIMEOUT = 4     # selected setpoint stream stale
uint8 FLAG_SATURATED = 8      # normalized torque saturated
uint8 FLAG_MODEL_INVALID = 16 # B1+B2 is singular or actuator model unavailable
uint8 FLAG_ACTUATOR_STALE = 32 # actuator command history is missing/stale
uint8 FLAG_HF_ENERGY = 64     # 25-50 Hz command energy exceeded the configured guard
uint8 FLAG_AUTO_FALLBACK = 128 # INDI output is latched out until disarm/mode reset
uint8 flags

uint8 FALLBACK_NONE = 0
uint8 FALLBACK_MODEL = 1
uint8 FALLBACK_SATURATION = 2
uint8 FALLBACK_ALLOCATION = 3
uint8 FALLBACK_HF_ENERGY = 4
uint8 fallback_reason
uint8 axis_mask               # bit 0 roll, bit 1 pitch, bit 2 yaw
uint8 actuator_model          # MC_INDI_ACT_SRC used by this sample

float32[3] omega_sp           # commanded body rates [rad/s]
float32[3] omega              # measured body rates [rad/s]
float32[3] omega_dot_raw      # unfiltered angular acceleration sample used by INDI [rad/s^2]
float32[3] omega_dot_f        # filtered measured angular acceleration [rad/s^2]

float32[3] nu                 # desired angular acceleration before compensation [rad/s^2]
float32[3] nu_comp            # applied angular acceleration compensation [rad/s^2]

float32[3] tau0_model         # actuator-model applied torque estimate before filter [N*m]
float32[3] tau0_f             # filtered applied torque estimate used by INDI [N*m]
float32[3] tau_comp           # applied torque compensation [N*m]
float32[3] tau_phys           # final physical torque command [N*m]
float32[3] tau_norm           # final normalized torque command [-1, 1]

float32[3] actuator_state     # delayed first-order normalized body-torque state
float32[3] actuator_state_f   # actuator state after the same H(z) as omega_dot
float32[3] command_increment  # u_c-u_f used by the dynamic inverse
float32[3] b2_accel           # B2*z^-1*(u_c-u_f) recurrence term [rad/s^2]
float32[4] motor_command      # latest post-allocation motor command, NaN if unavailable
float32 sensor_dt             # consecutive gyro timestamp_sample interval [s]
float32 filter_sample_rate    # smoothed sample rate used for H(z) coefficients [Hz]

float32[3] thrust_sp          # normalized thrust setpoint [-1, 1]
float32[4] q_sp               # desired attitude quaternion generated by accel-heading frontend
float32[3] accel_sp           # acceleration setpoint consumed by accel-heading frontend [m/s^2]
float32 heading_sp            # heading setpoint consumed by accel-heading frontend [rad]

# TOPICS indi_status
